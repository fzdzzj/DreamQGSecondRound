# ==================== 环境配置 ====================
# 运行环境：dev=开发环境 / prod=生产环境
SPRING_PROFILES_ACTIVE=dev

# ==================== 服务器配置 ====================
# 服务端口，默认 8080
SERVER_PORT=8080
# 日志级别：DEBUG / INFO / WARN / ERROR
LOG_LEVEL=INFO

# ==================== 数据库配置 ====================
# 数据库地址
DB_HOST=localhost
# 数据库端口
DB_PORT=3306
# 数据库名称
DB_NAME=dorm_repair
# 数据库用户名（请自行修改）
DB_USERNAME=your_db_username
# 数据库密码（请自行修改）
DB_PASSWORD=your_db_password

# ==================== 阿里云 OSS 配置 ====================
# 替换为自己的阿里云密钥
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET_NAME=your_bucket_name
OSS_REGION=cn-beijing

# ==================== JWT 配置 ====================
# JWT 签名密钥（自定义复杂字符串）
JWT_SIGN_KEY=your_jwt_sign_key
# JWT 过期时间（毫秒）：86400000 = 24 小时
JWT_EXPIRE=86400000
# JWT 刷新 Token 过期时间：604800000 = 7 天
JWT_REFRESH_EXPIRE=604800000
# 刷新 Token 签名密钥
JWT_REFRESH_SIGN_KEY=your_jwt_refresh_sign_key

# ==================== redis配置 ====================
SPRING_REDIS_URL=your_redis_url