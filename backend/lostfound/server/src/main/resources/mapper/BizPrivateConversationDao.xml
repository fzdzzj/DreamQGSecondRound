<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.qg.server.mapper.BizPrivateConversationDao">

    <select id="selectByUserIdAndPeerId" resultType="com.qg.pojo.entity.BizPrivateConversation">
        SELECT *
        FROM biz_private_conversation
        WHERE user_id = #{userId}
          AND peer_id = #{peerId}
    </select>

</mapper>
