<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="60 seconds" debug="false">
    <!-- 控制台输出 -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <!-- 格式化输出：%d 日期 %thread 线程名 %-5level 日志级别 %logger 类名 %msg 日志内容 %n 换行 -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset> <!-- 新增：避免中文乱码 -->
        </encoder>
    </appender>

    <!-- 系统文件输出 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 日志文件输出路径+名称（项目根目录下的logs文件夹） -->
            <FileNamePattern>logs/dormrepair-%d{yyyy-MM-dd}-%i.log</FileNamePattern>
            <!-- 最多保留30天日志 -->
            <MaxHistory>30</MaxHistory>
            <!-- 单个日志文件最大10MB -->
            <maxFileSize>10MB</maxFileSize>
            <!-- 新增：日志文件总大小上限，避免磁盘占满 -->
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>

        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset> <!-- 新增：避免中文乱码 -->
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/> <!-- 控制台输出 -->
        <appender-ref ref="FILE"/>   <!-- 文件输出 -->
    </root>


</configuration>